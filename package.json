{
  "name": "skill-marketplace",
  "private": true,
  "version": "0.2.0",
  "description": "Skill marketplace for GitHub Copilot CLI and Claude Code.",
  "type": "module",
  "bin": {
    "skill-marketplace": "./marketplace.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/targets/*"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test",
    "dev:api": "node apps/api/src/server.js",
    "dev:web": "node apps/web/src/server.js",
    "seed": "node scripts/seed.mjs",
    "cli": "node marketplace.mjs"
  }
}
